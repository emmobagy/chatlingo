    "@capacitor/ios": "^8.3.0",
    "@google/genai": "^1.48.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "otplib": "^13.4.0",

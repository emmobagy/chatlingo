{
  "name": "chatlingo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:safe": "rm -rf .next && next dev",
    "dev:ios": "npx concurrently \"next dev\" \"sleep 3 && npx cap open ios\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:ios": "BUILD_TARGET=capacitor next build && npx cap sync ios",
    "open:ios": "npx cap open ios",
    "cap:sync": "npx cap sync"
  },
